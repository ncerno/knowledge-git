// ──────────────────────────────────────────────
//  黑海岸·守望站  —  Prisma Schema v4
//  数据库：SQLite（本地轻量索引）
// ──────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ── 知识节点（与 initialRoadmaps.ts 对应）──
model KnowledgeNode {
  id             String   @id                // 与 initialRoadmaps 中的 id 对齐
  title          String
  description    String?
  category       String                       // frontend | backend | ai | gamedev | python
  depth          Int      @default(1)
  status         String   @default("locked") // locked | available | completed
  isMastered     Boolean  @default(false)
  slug           String?
  posX           Float    @default(0)
  posY           Float    @default(0)
  weight         Float    @default(1)
  prerequisiteId String?
  tags           String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  notes          Note[]                       // 1:N  一个节点可有多篇笔记
  tasks          Task[]

  @@index([category])
  @@index([status])
  @@index([isMastered])
}

// ── 笔记（多次迭代记录，关联知识节点）──
model Note {
  id          String   @id @default(cuid())
  title       String
  content     String   @default("")          // 富文本/Markdown 内容
  summary     String?                        // AI 摘要
  tags        String   @default("[]")
  version     Int      @default(1)
  nodeId      String?                        // 所属知识节点
  node        KnowledgeNode? @relation(fields: [nodeId], references: [id])
  wordCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([nodeId])
  @@index([createdAt])
}

// ── 任务管理 ──
model Task {
  id            String   @id @default(cuid())
  title         String
  description   String?
  status        String   @default("pending") // pending | active | completed | archived
  priority      Int      @default(0)         // 0=normal 1=high 2=urgent
  deadline      String?
  relatedNodeId String?
  relatedNode   KnowledgeNode? @relation(fields: [relatedNodeId], references: [id])
  completedAt   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([relatedNodeId])
}

// ── 学习记录（热力图 + 雷达图数据源）──
model StudyLog {
  id        String   @id @default(cuid())
  date      String                            // YYYY-MM-DD
  duration  Int      @default(0)             // 分钟
  category  String?                           // 领域分类
  nodeId    String?                           // 关联节点
  noteId    String?                           // 关联笔记
  action    String   @default("note")        // note | task | study
  createdAt DateTime @default(now())

  @@index([date])
  @@index([category])
}

// ── AI 学习总结 ──
model LearningSummary {
  id        String   @id @default(cuid())
  type      String                            // weekly | monthly | domain
  period    String                            // 如 "2025-W03" 或 "2025-01" 或 "frontend"
  content   String   @default("")
  source    String   @default("ai")          // ai | manual
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, period])
}
