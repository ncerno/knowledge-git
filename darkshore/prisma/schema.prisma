// ──────────────────────────────────────────────
//  黑海岸·守望站  —  Prisma Schema  v2
//  数据库：SQLite（本地轻量索引）
//  Phase II: KnowledgeNode 知识星图节点
// ──────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── 笔记索引表（物理文件存储在 /notes/*.md）───
model Note {
  id          String   @id @default(cuid())
  slug        String   @unique          // 文件名（不含 .md）
  title       String
  summary     String?                   // AI 摘要（后续阶段）
  tags        String   @default("[]")  // JSON 数组序列化
  domain      String?                   // 所属领域
  filePath    String                    // 物理路径
  wordCount   Int      @default(0)
  readingMins Int      @default(0)
  isMastered  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skills SkillNote[]
}

// ─── 技能 / Roadmap 节点（旧版，保持兼容）───
model Skill {
  id          String      @id @default(cuid())
  name        String      @unique
  domain      String
  description String?
  level       Int         @default(0)
  orderIndex  Int         @default(0)
  parentId    String?
  parent      Skill?      @relation("SkillTree", fields: [parentId], references: [id])
  children    Skill[]     @relation("SkillTree")
  notes       SkillNote[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ─── 笔记-技能 中间表 ───
model SkillNote {
  noteId  String
  skillId String
  note    Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([noteId, skillId])
}

// ─── 学习记录 ───
model StudyLog {
  id        String   @id @default(cuid())
  date      String
  duration  Int      @default(0)
  noteId    String?
  tags      String   @default("[]")
  createdAt DateTime @default(now())

  @@unique([date])
}

// ────────────────────────────────────────────────────────────
//  KnowledgeNode — 知识星图节点（Phase II 核心模型）
//  每个节点对应星图中的一颗「星」，形成五大星域的知识网络
// ────────────────────────────────────────────────────────────
model KnowledgeNode {
  id          String   @id @default(cuid())

  // 节点基本信息
  title       String                        // 节点名称，如 "React Hooks"
  description String?                       // 简短描述

  // 五大领域分类（严格枚举值）
  // frontend | backend | ai | gamedev | python
  category    String

  // 在该领域内的层级深度（0=根节点/领域中心，1=一级主题，2=二级子主题）
  depth       Int      @default(1)

  // 学习状态
  // locked=未解锁（灰色微光）| available=可学习（白色亮光）| completed=已完成（青色荧光）
  status      String   @default("locked")

  // 关联 Markdown 笔记文件（slug = notes/ 下的文件名，不含 .md）
  slug        String?  @unique

  // 星图坐标权重（用于 D3 力导向图的初始布局提示）
  // x/y 为 -1.0 ~ 1.0 的相对坐标，由前端映射到实际画布
  posX        Float    @default(0)
  posY        Float    @default(0)

  // 节点重要性权重（影响星图中节点的视觉大小）
  weight      Float    @default(1.0)

  // 树形自关联：prerequisiteId 指向前置节点（父节点）
  prerequisiteId String?
  prerequisite   KnowledgeNode?  @relation("NodeTree", fields: [prerequisiteId], references: [id])
  dependents     KnowledgeNode[] @relation("NodeTree")

  // 额外标签（JSON序列化数组）
  tags        String   @default("[]")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([prerequisiteId])
}

