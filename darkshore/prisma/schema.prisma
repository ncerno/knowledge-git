// --------------------------------------------------
//  Darkshore - Prisma Schema
//  SQLite - url configured in prisma.config.ts
// --------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model KnowledgeNode {
  id             String   @id
  title          String
  description    String?
  category       String
  depth          Int      @default(1)
  status         String   @default("locked")
  isMastered     Boolean  @default(false)
  slug           String?
  posX           Float    @default(0)
  posY           Float    @default(0)
  weight         Float    @default(1)
  prerequisiteId String?
  tags           String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  notes          Note[]
  tasks          Task[]
  @@index([category])
  @@index([status])
  @@index([isMastered])
}

model Note {
  id          String   @id @default(cuid())
  title       String
  content     String   @default("")
  summary     String?
  tags        String   @default("[]")
  version     Int      @default(1)
  nodeId      String?
  node        KnowledgeNode? @relation(fields: [nodeId], references: [id])
  wordCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([nodeId])
  @@index([createdAt])
}

model Task {
  id            String   @id @default(cuid())
  title         String
  description   String?
  status        String   @default("pending")
  priority      Int      @default(0)
  deadline      String?
  relatedNodeId String?
  relatedNode   KnowledgeNode? @relation(fields: [relatedNodeId], references: [id])
  completedAt   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([status])
  @@index([relatedNodeId])
}

model StudyLog {
  id        String   @id @default(cuid())
  date      String
  duration  Int      @default(0)
  category  String?
  nodeId    String?
  noteId    String?
  action    String   @default("note")
  source    String   @default("manual")
  inputType String?
  periodKey String?
  metadata  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([date])
  @@index([category])
  @@index([action])
  @@index([nodeId])
}

model LearningSummary {
  id          String   @id @default(cuid())
  type        String
  period      String
  title       String   @default("")
  category    String?
  content     String   @default("")
  contentHtml String   @default("")
  excerpt     String   @default("")
  source      String   @default("ai")
  status      String   @default("published")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([type, period])
  @@index([type, createdAt])
  @@index([category])
}
